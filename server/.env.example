PORT=5000
NODE_ENV=development

# PostgreSQL Database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/ipl_booking

# Redis (Upstash) for Seat Locking and Queue
UPSTASH_REDIS_REST_URL=redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# Razorpay (Payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# JWT Secret (For QR Code Tickets)
JWT_SECRET=your_secure_random_jwt_secret
JWT_EXPIRES_IN=24h

# Brevo SMTP Settings (for Email Verification)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM=your_verified_sender_email@domain.com
