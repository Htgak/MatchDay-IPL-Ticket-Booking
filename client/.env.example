# Supabase credentials are required if the client interacts with Supabase directly for Auth.
# Currently the backend acts as a proxy, but usually React apps use Supabase Auth directly.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay key id for the checkout widget
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Backend API URL
VITE_API_BASE_URL=http://localhost:5000/api
